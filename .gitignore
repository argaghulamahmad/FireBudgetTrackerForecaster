# =============================================================================
# Dependencies
# =============================================================================
node_modules/
pnpm-debug.log*
package-lock.json        # Use pnpm-lock.yaml instead

# =============================================================================
# Build & Distribution Outputs
# =============================================================================
dist/
dev-dist/
build/
dist-ssr/
*.tsbuildinfo            # TypeScript incremental build cache

# =============================================================================
# Runtime & Environment
# =============================================================================
.env
.env.local
.env.*.local             # Matches .env.development.local, .env.test.local, etc.
!.env.example            # Track template only

# =============================================================================
# Firebase
# =============================================================================
.firebase/
.firebaserc              # May contain project references (add to .gitignore.local if sensitive)
.runtimeconfig.json

# =============================================================================
# Testing & Coverage
# =============================================================================
coverage/
*.lcov
.nyc_output/

# =============================================================================
# IDE & Editor Config
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.vscode-test/
*.code-workspace

# =============================================================================
# Caching & Build Artifacts
# =============================================================================
.vite/
.eslintcache
.cache/
.parcel-cache
.next/

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# =============================================================================
# OS-Specific Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# =============================================================================
# Certificates & Keys (Security)
# =============================================================================
*.pem
*.pfx
*.p12
*.key
*.cert

# =============================================================================
# Miscellaneous
# =============================================================================
.env.production.local
dist-ssr/
*.local
.vercel/
out/
